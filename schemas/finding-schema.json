{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Finding with CWE/OWASP mapping",
  "type": "object",
  "properties": {
    "id": {"type":"string"},
    "title": {"type":"string"},
    "asset": {"type":"string"},
    "class": {"type":"string","enum":["access-control","injection","ssrf","business-logic","race-condition","auth-session","api-misconfig","info-disclosure","crypto","other"]},
    "cwe_id": {"type":"string","pattern":"^CWE-\\d+$","description":"CWE identifier, e.g. CWE-639"},
    "owasp_category": {"type":"string","enum":["A01:2021-Broken Access Control","A02:2021-Cryptographic Failures","A03:2021-Injection","A04:2021-Insecure Design","A05:2021-Security Misconfiguration","A06:2021-Vulnerable and Outdated Components","A07:2021-Identification and Authentication Failures","A08:2021-Software and Data Integrity Failures","A09:2021-Security Logging and Monitoring Failures","A10:2021-Server-Side Request Forgery"]},
    "cvss_vector": {"type":"string","description":"CVSS v3.1 vector string"},
    "cvss_score": {"type":"number","minimum":0,"maximum":10},
    "severity": {"type":"string","enum":["none","low","medium","high","critical"]},
    "boundary": {"type":"string"},
    "preconditions": {"type":"string"},
    "steps": {"type":"array","items":{"type":"string"}},
    "expected": {"type":"string"},
    "actual": {"type":"string"},
    "impact": {"type":"string"},
    "confidence": {"type":"string","enum":["lead","candidate","validated","reportable"]},
    "risk_score": {"type":"integer","minimum":0,"maximum":15},
    "controls": {"type":"object"},
    "evidence_refs": {"type":"array","items":{"type":"string"}},
    "redacted": {"type":"boolean"},
    "remediation": {"type":"string"},
    "references": {"type":"array","items":{"type":"string"},"description":"URLs to CWE, OWASP, CVE, or vendor advisories"},
    "status": {"type":"string","enum":["draft","validating","validated","submitted","duplicate","won't-fix","invalid"]}
  },
  "required": ["id","title","asset","class","cwe_id","owasp_category","impact","confidence","risk_score","redacted","status"]
}
